{
  "name": "cbpanel",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx server/index.ts",
    "frontend:dev": "vite --host 127.0.0.1",
    "server:desktop": "cross-env CBPANEL_SHELL=desktop CBPANEL_API_ONLY=1 tsx server/index.ts",
    "build": "tsc --noEmit && vite build",
    "analyze": "cross-env CBPANEL_ANALYZE=1 vite build",
    "bundle:baseline": "node scripts/check-bundle-baseline.mjs",
    "bundle:baseline:update": "node scripts/check-bundle-baseline.mjs --update",
    "tauri": "tauri",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "desktop:portable": "node scripts/build-windows-portable.mjs",
    "sidecar:build": "node scripts/build-sidecar.mjs",
    "release:windows": "node scripts/release-windows.mjs",
    "release:linux": "node scripts/release-linux.mjs",
    "release:mac": "node scripts/release-mac.mjs",
    "release:smoke": "node scripts/smoke-release.mjs",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts server/**/*.test.ts",
    "preview": "cross-env NODE_ENV=production tsx server/index.ts"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.18",
    "@radix-ui/react-checkbox": "^1.3.6",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-scroll-area": "^1.2.13",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-switch": "^1.3.2",
    "@radix-ui/react-tabs": "^1.1.16",
    "@radix-ui/react-tooltip": "^1.2.11",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@vitejs/plugin-react": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "cloakbrowser": "^0.4.8",
    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "fflate": "^0.8.3",
    "lucide-react": "^1.23.0",
    "mmdb-lib": "^3.0.2",
    "playwright-core": "^1.61.1",
    "puppeteer-core": "^25.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "socks-proxy-agent": "^10.1.0",
    "sonner": "^2.0.7",
    "subsetted-fonts": "^1.0.4",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tar": "^7.5.19",
    "undici": "^8.7.0",
    "vite": "^8.1.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@yao-pkg/pkg": "^6.21.0",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
